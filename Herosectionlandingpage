<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>The Putting Method — Hero Prototype</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --page-bg: #07140F;
    --hero-bg: #0D1C15;
    --surface: #12231A;
    --raised: #1A2D22;
    --accent: #D7B76D;
    --accent-secondary: #8FA77A;
    --text-primary: #F5F1E7;
    --text-secondary: #C9C2B4;
    --text-muted: #879084;
    --border: #263A30;
    --accent-border: rgba(215, 183, 109, 0.30);
    --nav-bg: #FFFDF8;
    --nav-text: #07140F;
    --paper: var(--page-bg);
    --paper-2: var(--hero-bg);
    --ink: var(--nav-text);
    --muted: var(--text-muted);
    --forest: var(--page-bg);
    --forest-2: var(--hero-bg);
    --fairway: var(--accent-secondary);
    --brass: var(--accent);
    --sand: var(--text-secondary);
    --line: var(--border);
    --white: var(--text-primary);
    --shadow: 0 30px 100px rgba(7, 20, 15, 0.46), 0 12px 42px rgba(7, 20, 15, 0.34);
    --type-nav: 13px;
    --type-brand-kicker: 10px;
    --type-eyebrow: 12px;
    --type-hero: clamp(48px, 6.6vw, 86px);
    --type-lead: clamp(18px, 1.75vw, 22px);
    --type-button: 14px;
    --type-proof: 11px;
    --type-card-title: 18px;
    --type-card-body: 14px;
    --space-1: 8px;
    --space-2: 12px;
    --space-3: 16px;
    --space-4: 20px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 40px;
    --space-8: 56px;
    --space-9: 72px;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text-primary);
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at 50% -12%, rgba(215, 183, 109, 0.16), transparent 32rem),
      radial-gradient(circle at 12% 18%, rgba(143, 167, 122, 0.18), transparent 30rem),
      var(--page-bg);
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: .32;
    background-image:
      linear-gradient(rgba(215, 183, 109, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(215, 183, 109, 0.03) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, black, transparent 82%);
    z-index: 0;
  }

  body::after {
    content: "";
    position: fixed;
    inset: auto -8vw -28vh -8vw;
    height: 46vh;
    pointer-events: none;
    background:
      repeating-radial-gradient(ellipse at center, rgba(143, 167, 122, .14) 0 2px, transparent 2px 18px);
    transform: rotate(-2deg);
    opacity: .45;
    z-index: 0;
  }

  .site {
    position: relative;
    z-index: 1;
    background: var(--page-bg);
  }

  .nav {
    width: min(1220px, calc(100vw - 40px));
    margin: 0 auto;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--nav-bg);
    border-bottom: 1px solid rgba(7, 20, 15, 0.12);
    box-shadow: 0 0 0 100vmax var(--nav-bg);
    clip-path: inset(0 -100vmax);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--nav-text);
    text-decoration: none;
    font-weight: 750;
    letter-spacing: -0.035em;
  }

  .brand-mark {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    color: var(--accent);
    background: linear-gradient(145deg, var(--page-bg), var(--hero-bg));
    box-shadow: inset 0 0 0 1px var(--accent-border), 0 10px 24px rgba(7, 20, 15, .18);
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    letter-spacing: -0.08em;
  }

  .brand small {
    display: block;
    margin-top: 2px;
    color: rgba(7,20,15,.62);
    font-family: "JetBrains Mono", monospace;
    font-size: var(--type-brand-kicker);
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    font-size: var(--type-nav);
    font-weight: 700;
  }

  .nav-links a {
    color: rgba(7,20,15,.72);
    text-decoration: none;
  }

  .nav-cta {
    padding: 12px 18px;
    border-radius: 999px;
    color: var(--accent) !important;
    background: var(--page-bg);
    box-shadow: 0 14px 28px rgba(7,20,15,.18);
  }

  .hero {
    width: 100%;
    margin: 0;
    padding: var(--space-6) 0 var(--space-9);
    background: var(--hero-bg);
    color: var(--text-primary);
    border-bottom: 1px solid var(--accent-border);
  }

  .device-stage {
    position: relative;
    display: grid;
    place-items: center;
    padding: clamp(16px, 2vw, 24px) 0 var(--space-5);
  }

  .device-stage::before {
    content: "";
    position: absolute;
    width: min(940px, 78vw);
    height: 220px;
    bottom: 8px;
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(7,20,15,.55), rgba(7,20,15,0) 70%);
    filter: blur(20px);
    z-index: 0;
  }

  .phone {
    position: relative;
    z-index: 1;
    width: min(1120px, 94vw);
    aspect-ratio: 2.26 / 1;
    padding: clamp(14px, 2.2vw, 28px);
    border-radius: clamp(38px, 5.5vw, 78px);
    background: linear-gradient(145deg, var(--raised) 0%, var(--page-bg) 38%, var(--surface) 100%);
    box-shadow: var(--shadow), inset 0 0 0 2px rgba(255,255,255,.08), inset 0 -10px 28px rgba(255,255,255,.05);
    transform: perspective(1400px) rotateX(2deg);
  }

  .phone::before,
  .phone::after {
    content: "";
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 999px;
    background: linear-gradient(180deg, var(--raised), var(--page-bg));
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
  }

  .phone::before {
    left: 10px;
    width: 6px;
    height: 84px;
  }

  .phone::after {
    right: 18px;
    width: clamp(8px, 1vw, 12px);
    height: clamp(8px, 1vw, 12px);
    background: radial-gradient(circle at 35% 35%, var(--border), var(--page-bg) 70%);
  }

  .phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: clamp(26px, 3.6vw, 48px);
    background: var(--page-bg);
    box-shadow: inset 0 0 0 1px var(--accent-border), inset 0 0 44px rgba(255,255,255,.035);
  }

  .phone-screen::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 8px;
    transform: translateX(-50%);
    width: 110px;
    height: 22px;
    border-radius: 999px;
    background: var(--surface);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.08), 0 6px 16px rgba(0,0,0,.25);
    z-index: 2;
    opacity: .78;
  }

  .tempo-frame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: var(--page-bg);
  }

  .hero-copy {
    max-width: 900px;
    margin: clamp(28px, 4vw, 44px) auto 0;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-size: var(--type-eyebrow);
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .eyebrow::before,
  .eyebrow::after {
    content: "";
    width: 38px;
    height: 1px;
    background: var(--accent-border);
  }

  h1 {
    margin: var(--space-4) 0 var(--space-3);
    font-size: var(--type-hero);
    line-height: .96;
    letter-spacing: -0.068em;
    font-weight: 820;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-copy p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: var(--type-lead);
    line-height: 1.52;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }

  .btn {
    appearance: none;
    border: 0;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 var(--space-5);
    border-radius: 999px;
    font-weight: 800;
    font-size: var(--type-button);
    letter-spacing: -0.01em;
  }

  .btn-primary {
    color: var(--page-bg);
    background: var(--accent);
    box-shadow: 0 18px 34px rgba(7,20,15,.30);
  }

  .btn-secondary {
    color: var(--text-primary);
    background: var(--raised);
    border: 1px solid var(--accent-border);
    box-shadow: 0 12px 28px rgba(7,20,15,.22);
  }

  .proof-row {
    margin-top: var(--space-5);
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .proof-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 9px 13px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(18, 35, 26, .78);
    color: var(--text-secondary);
    font-family: "JetBrains Mono", monospace;
    font-size: var(--type-proof);
    font-weight: 700;
    letter-spacing: .02em;
  }

  .proof-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px rgba(215,183,109,.16);
  }

  .diagnostic-section {
    position: relative;
    background: #FFFFFF;
    color: var(--nav-text);
    padding: clamp(64px, 8vw, 108px) 0;
    border-bottom: 1px solid rgba(7, 20, 15, 0.10);
  }

  .diagnostic-anchor {
    position: absolute;
    top: -80px;
  }

  .diagnostic-wrap {
    width: min(1120px, calc(100vw - 40px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, .86fr) minmax(420px, 1fr);
    align-items: center;
    gap: clamp(36px, 6vw, 84px);
  }

  .diagnostic-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    color: var(--accent-secondary);
    font-family: "JetBrains Mono", monospace;
    font-size: var(--type-eyebrow);
    font-weight: 800;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .diagnostic-kicker::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent-secondary);
    box-shadow: 0 0 0 4px rgba(143, 167, 122, .16);
  }

  .diagnostic-copy h2 {
    margin: 0 0 var(--space-4);
    max-width: 620px;
    color: var(--nav-text);
    font-size: clamp(44px, 5.5vw, 76px);
    line-height: .96;
    letter-spacing: -0.07em;
  }

  .diagnostic-copy p {
    max-width: 620px;
    margin: 0;
    color: rgba(7, 20, 15, .74);
    font-size: clamp(17px, 1.55vw, 21px);
    line-height: 1.55;
    letter-spacing: -0.025em;
  }

  .diagnostic-points {
    display: grid;
    gap: var(--space-3);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }

  .diagnostic-points li {
    display: grid;
    grid-template-columns: 13px 1fr;
    gap: var(--space-3);
    align-items: start;
    color: rgba(7, 20, 15, .78);
    font-size: 15px;
    font-weight: 750;
    line-height: 1.45;
  }

  .diagnostic-points li::before {
    content: "";
    width: 9px;
    height: 9px;
    margin-top: 6px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 5px rgba(215, 183, 109, .16);
  }

  .diagnostic-panel {
    position: relative;
    overflow: hidden;
    min-height: 500px;
    padding: clamp(24px, 3vw, 34px);
    border-radius: 34px;
    color: var(--text-primary);
    background:
      radial-gradient(circle at 80% 0%, rgba(215, 183, 109, .12), transparent 24rem),
      linear-gradient(145deg, var(--surface), var(--page-bg));
    border: 1px solid var(--accent-border);
    box-shadow: 0 28px 70px rgba(7, 20, 15, .22), inset 0 0 0 1px rgba(245, 241, 231, .04);
  }

  .diagnostic-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(245, 241, 231, .035) 1px, transparent 1px);
    background-size: 100% 4px;
    opacity: .55;
  }

  .diagnostic-panel > * {
    position: relative;
    z-index: 1;
  }

  .diagnostic-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .diagnostic-label,
  .diagnostic-step {
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .diagnostic-step {
    color: var(--accent);
    white-space: nowrap;
  }

  .diagnostic-progress {
    height: 5px;
    margin-bottom: var(--space-5);
    overflow: hidden;
    border-radius: 999px;
    background: rgba(245, 241, 231, .09);
  }

  .diagnostic-progress span {
    display: block;
    width: 16.666%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), var(--accent-secondary));
    transition: width .28s ease;
  }

  .diagnostic-question h3 {
    margin: 0 0 var(--space-2);
    color: var(--text-primary);
    font-size: clamp(25px, 3vw, 34px);
    line-height: 1.05;
    letter-spacing: -0.045em;
  }

  .diagnostic-helper {
    margin: 0 0 var(--space-5);
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.55;
  }

  .diagnostic-options {
    display: grid;
    gap: var(--space-2);
  }

  .diagnostic-option {
    width: 100%;
    min-height: 56px;
    padding: 0 var(--space-4);
    border-radius: 15px;
    border: 1px solid rgba(245, 241, 231, .10);
    color: var(--text-primary);
    background: rgba(26, 45, 34, .72);
    box-shadow: inset 0 0 0 1px rgba(245, 241, 231, .025);
    font: inherit;
    font-size: 15px;
    font-weight: 800;
    text-align: left;
    cursor: pointer;
    transition: border-color .18s ease, background .18s ease, transform .18s ease;
  }

  .diagnostic-option:hover,
  .diagnostic-option.is-selected {
    border-color: var(--accent-border);
    background: var(--raised);
    transform: translateY(-1px);
  }

  .diagnostic-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .diagnostic-back,
  .diagnostic-next,
  .diagnostic-reset,
  .diagnostic-convert {
    min-height: 48px;
    padding: 0 var(--space-5);
    border-radius: 999px;
    font: inherit;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .diagnostic-back,
  .diagnostic-reset {
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid rgba(245, 241, 231, .16);
  }

  .diagnostic-next,
  .diagnostic-convert {
    color: var(--page-bg);
    background: var(--accent);
    border: 1px solid var(--accent);
    box-shadow: 0 14px 30px rgba(215, 183, 109, .18);
  }

  .diagnostic-next:disabled {
    cursor: not-allowed;
    opacity: .48;
  }

  .diagnostic-result {
    display: none;
  }

  .diagnostic-result.is-visible {
    display: block;
  }

  .diagnostic-result h3 {
    margin: 0 0 var(--space-3);
    color: var(--text-primary);
    font-size: clamp(29px, 3vw, 38px);
    line-height: 1.05;
    letter-spacing: -0.045em;
  }

  .diagnostic-insight {
    margin: 0 0 var(--space-5);
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.58;
  }

  .practice-block {
    margin: 0 0 var(--space-6);
    padding: var(--space-4);
    border-radius: 18px;
    color: var(--text-secondary);
    background: rgba(26, 45, 34, .78);
    border: 1px solid var(--border);
  }

  .practice-block strong {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .result-actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  @media (max-width: 820px) {
    .nav { height: 72px; width: min(100vw - 28px, 1220px); }
    .nav-links a:not(.nav-cta) { display: none; }
    .brand small { display: none; }
    .phone { width: 1080px; max-width: calc(100vw - 18px); padding: 10px; border-radius: 38px; transform: none; }
    .phone-screen { border-radius: 28px; }
    .phone-screen::before { width: 72px; height: 14px; top: 5px; }
    .hero { padding-top: var(--space-5); }
    .hero-copy { margin-top: var(--space-6); }
    h1 { font-size: clamp(42px, 12vw, 58px); }
    .diagnostic-wrap { grid-template-columns: 1fr; }
    .diagnostic-panel { min-height: auto; }
  }

  @media (max-width: 540px) {
    .hero { width: 100%; }
    .phone { aspect-ratio: 1.95 / 1; }
    .hero-actions { align-items: stretch; }
    .btn { width: 100%; }
  }
</style>
</head>
<body>
  <div class="site">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="The Putting Method home">
        <span class="brand-mark">PM</span>
        <span>The Putting Method<small>Line · Speed · Tempo · Proof</small></span>
      </a>
      <div class="nav-links" aria-label="Main links">
        <a href="#trainer">Trainer</a>
        <a href="#method">Method</a>
        <a href="#pricing">Pricing</a>
        <a class="nav-cta" href="#start">Start training</a>
      </div>
    </nav>

    <main id="top" class="hero">
      <section class="device-stage" id="trainer" aria-label="Tempo Trainer preview in landscape phone">
        <div class="phone" aria-label="Landscape phone showing the Tempo Trainer app">
          <div class="phone-screen">
            <iframe class="tempo-frame" title="Interactive Putting Tempo Trainer" src="https://ccsedge.github.io/Putting-App/"></iframe>
          </div>
        </div>
      </section>

      <section class="hero-copy" aria-label="Hero message">
        <div class="eyebrow">Train the part of golf everyone can master</div>
        <h1>Every golfer can putt like an elite player.</h1>
        <p>You do not need tour-level speed, strength, or athleticism to become dangerous on the greens. You need a measurable system for start line, speed, tempo, green reading, and pressure — then a way to prove the work is lowering your score.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#start">Build my putting baseline</a>
          <a class="btn btn-secondary" href="#method">See the system</a>
        </div>
        <div class="proof-row" aria-label="Platform highlights">
          <span class="proof-pill"><span class="proof-dot"></span>14-day trial · no credit card</span>
          <span class="proof-pill"><span class="proof-dot"></span>Tempo · green reading · strokes gained</span>
          <span class="proof-pill"><span class="proof-dot"></span>Built for practice and the course</span>
        </div>
      </section>
    </main>

    <section class="diagnostic-section" id="method" aria-label="Putting baseline diagnostic">
      <div class="diagnostic-anchor" id="start" aria-hidden="true"></div>
      <div class="diagnostic-wrap">
        <div class="diagnostic-copy">
          <div class="diagnostic-kicker">Start with the leak</div>
          <h2>Stop guessing what to practice.</h2>
          <p>Most golfers know they are leaving shots on the green. The hard part is knowing whether the leak is start line, speed control, green reading, tempo, or pressure. Answer six questions and get a focused first practice block instantly.</p>
          <ul class="diagnostic-points">
            <li>Identify the putting pattern costing you the most confidence.</li>
            <li>Get one useful practice recommendation before committing to a full plan.</li>
            <li>Use the diagnosis to connect the Tempo Trainer, green cards, and strokes-gained dashboard.</li>
          </ul>
        </div>

        <div class="diagnostic-panel" data-diagnostic>
          <div class="diagnostic-quiz" data-quiz>
            <div class="diagnostic-topline">
              <span class="diagnostic-label">Baseline diagnostic</span>
              <span class="diagnostic-step" data-step>Step 1 of 6</span>
            </div>
            <div class="diagnostic-progress" aria-hidden="true"><span data-progress></span></div>
            <div class="diagnostic-question">
              <h3 data-question>What putt costs you the most confidence?</h3>
              <p class="diagnostic-helper" data-helper>Choose the situation that feels most expensive during a real round.</p>
              <div class="diagnostic-options" data-options></div>
            </div>
            <div class="diagnostic-controls">
              <button class="diagnostic-back" type="button" data-back>Back</button>
              <button class="diagnostic-next" type="button" data-next disabled>Continue</button>
            </div>
          </div>

          <div class="diagnostic-result" data-result aria-live="polite">
            <div class="diagnostic-topline">
              <span class="diagnostic-label">Your first read</span>
              <span class="diagnostic-step">Instant insight</span>
            </div>
            <h3 data-result-title>Your biggest leak is speed control.</h3>
            <p class="diagnostic-insight" data-result-copy>Your answers point to distance control and capture speed as the highest-leverage place to start.</p>
            <div class="practice-block">
              <strong>First practice block</strong>
              <span data-result-drill>Run a 10, 20, 30, and 40-foot ladder. Finish each ball inside a 24-inch window and track short vs. long misses.</span>
            </div>
            <div class="result-actions">
              <a class="diagnostic-convert" href="#pricing">Build my full plan</a>
              <button class="diagnostic-reset" type="button" data-reset>Retake diagnostic</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

<script>
(function() {
  const questions = [
    {
      title: 'What putt costs you the most confidence?',
      helper: 'Choose the situation that feels most expensive during a real round.',
      options: [
        ['3–6 footers that should be automatic', 'startline'],
        ['25–40 foot lag putts', 'speed'],
        ['Breaking putts where read and speed fight', 'read'],
        ['Tournament or money-game putts', 'pressure']
      ]
    },
    {
      title: 'Where do most of your missed putts finish?',
      helper: 'The miss pattern usually tells you what should be trained first.',
      options: [
        ['Low side of the hole', 'read'],
        ['High side of the hole', 'speed'],
        ['Short and never had a chance', 'speed'],
        ['Pushed or pulled off the intended line', 'startline']
      ]
    },
    {
      title: 'Which speed-control mistake shows up most?',
      helper: 'Speed control drives three-putt avoidance and makes green reading easier.',
      options: [
        ['Leaving long putts 4+ feet short', 'speed'],
        ['Running comebackers outside 3 feet', 'speed'],
        ['Changing tempo from putt to putt', 'tempo'],
        ['Choosing a safer line because speed feels uncertain', 'read']
      ]
    },
    {
      title: 'What condition changes your putting the most?',
      helper: 'This helps separate a stroke issue from a calibration issue.',
      options: [
        ['Fast greens', 'tempo'],
        ['Slow greens', 'speed'],
        ['Grainy Bermuda', 'read'],
        ['Severe slope or tiered greens', 'read']
      ]
    },
    {
      title: 'What do you practice least consistently?',
      helper: 'The missing piece is often the one that makes the rest of the work transfer.',
      options: [
        ['Start line gates or face control', 'startline'],
        ['Tempo and stroke length calibration', 'tempo'],
        ['Structured green-reading reps', 'read'],
        ['Pressure tests that simulate score consequences', 'pressure']
      ]
    },
    {
      title: 'What would make the next 30 days feel successful?',
      helper: 'The platform turns this goal into a measurable plan.',
      options: [
        ['Stop three-putting', 'speed'],
        ['Make more putts inside 8 feet', 'startline'],
        ['Read breaking putts with more conviction', 'read'],
        ['Feel ready over tournament putts', 'pressure']
      ]
    }
  ];

  const results = {
    speed: {
      title: 'Your first leak appears to be speed control.',
      copy: 'Your answers point to distance control and capture speed as the fastest place to win strokes. Before changing mechanics, calibrate how far the ball rolls from a repeatable stroke length.',
      drill: 'Run a 10, 20, 30, and 40-foot ladder. Finish each ball inside a 24-inch window and track whether misses finish short or long.'
    },
    startline: {
      title: 'Your first leak appears to be start line.',
      copy: 'Your answers point to face control and launch direction. The goal is not to manipulate the stroke — it is to prove you can start the ball where you intend under repeatable conditions.',
      drill: 'Set a gate 18 inches in front of the ball. Hit 30 putts from 5–8 feet and record how many start online before judging make or miss.'
    },
    read: {
      title: 'Your first leak appears to be green reading.',
      copy: 'Your answers suggest read, speed, and slope calibration are not matching. The fastest win is building a reliable reference for how break changes by distance, stimp, slope, grain, and capture speed.',
      drill: 'Pick one 12-foot breaking putt. Hit three capture speeds — die, 12 inches past, and 24 inches past — and note how much the start line changes.'
    },
    tempo: {
      title: 'Your first leak appears to be tempo calibration.',
      copy: 'Your answers point to inconsistent rhythm and stroke length. A stable tempo makes speed predictable, especially when green speed or pressure changes.',
      drill: 'Use the Tempo Trainer for 5, 10, 20, and 30-foot putts. Match the same rhythm while changing only stroke length.'
    },
    pressure: {
      title: 'Your first leak appears to be pressure transfer.',
      copy: 'Your answers suggest the stroke may work in practice but not under consequence. The priority is making practice feel more like the putts that matter.',
      drill: 'Create a 12-putt test from 4–8 feet. You must restart if you miss two in a row. Track score, heart rate feel, and miss direction.'
    }
  };

  const quiz = document.querySelector('[data-quiz]');
  const result = document.querySelector('[data-result]');
  if (!quiz || !result) return;

  const stepEl = document.querySelector('[data-step]');
  const progressEl = document.querySelector('[data-progress]');
  const questionEl = document.querySelector('[data-question]');
  const helperEl = document.querySelector('[data-helper]');
  const optionsEl = document.querySelector('[data-options]');
  const backBtn = document.querySelector('[data-back]');
  const nextBtn = document.querySelector('[data-next]');
  const resetBtn = document.querySelector('[data-reset]');
  const resultTitle = document.querySelector('[data-result-title]');
  const resultCopy = document.querySelector('[data-result-copy]');
  const resultDrill = document.querySelector('[data-result-drill]');

  let current = 0;
  const answers = new Array(questions.length).fill(null);

  function renderQuestion() {
    const q = questions[current];
    stepEl.textContent = `Step ${current + 1} of ${questions.length}`;
    progressEl.style.width = `${((current + 1) / questions.length) * 100}%`;
    questionEl.textContent = q.title;
    helperEl.textContent = q.helper;
    optionsEl.innerHTML = '';

    q.options.forEach(([label, focus], index) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'diagnostic-option';
      btn.textContent = label;
      btn.dataset.focus = focus;
      if (answers[current] && answers[current].index === index) btn.classList.add('is-selected');
      btn.addEventListener('click', () => {
        answers[current] = { label, focus, index };
        [...optionsEl.children].forEach(child => child.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        nextBtn.disabled = false;
      });
      optionsEl.appendChild(btn);
    });

    backBtn.style.visibility = current === 0 ? 'hidden' : 'visible';
    nextBtn.textContent = current === questions.length - 1 ? 'Show insight' : 'Continue';
    nextBtn.disabled = !answers[current];
  }

  function showResult() {
    const scores = answers.reduce((acc, answer) => {
      if (!answer) return acc;
      acc[answer.focus] = (acc[answer.focus] || 0) + 1;
      return acc;
    }, {});
    const winner = Object.entries(scores).sort((a, b) => b[1] - a[1])[0]?.[0] || 'speed';
    const insight = results[winner];

    resultTitle.textContent = insight.title;
    resultCopy.textContent = insight.copy;
    resultDrill.textContent = insight.drill;
    quiz.style.display = 'none';
    result.classList.add('is-visible');
  }

  backBtn.addEventListener('click', () => {
    if (current > 0) {
      current -= 1;
      renderQuestion();
    }
  });

  nextBtn.addEventListener('click', () => {
    if (!answers[current]) return;
    if (current < questions.length - 1) {
      current += 1;
      renderQuestion();
    } else {
      showResult();
    }
  });

  resetBtn.addEventListener('click', () => {
    current = 0;
    answers.fill(null);
    result.classList.remove('is-visible');
    quiz.style.display = 'block';
    renderQuestion();
  });

  renderQuestion();
})();
</script>
</body>
</html>
